# AgentWorks 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ============================================
# LLM API 配置（必需）
# ============================================

# DeepSeek API 配置
NEXT_PUBLIC_DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1
NEXT_PUBLIC_DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 通用 LLM API 配置（可选）
NEXT_PUBLIC_LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_API_KEY=your-llm-api-key-here

# ============================================
# WebSocket 实时通信（可选）
# ============================================
# 不配置则使用本地模式
NEXT_PUBLIC_WS_URL=

# ============================================
# 数据库配置（可选）
# ============================================
# SQLite 数据库路径（服务端，默认 data/agentworks.db）
DATABASE_PATH=

# ============================================
# 短信网关配置（可选）
# ============================================
# 用于休息模式短信摘要 SOLO-01
# 支持通用 HTTP 短信网关（Twilio / 阿里云短信 / 自建网关等）
SMS_GATEWAY_URL=
SMS_GATEWAY_SECRET=
SMS_RECIPIENT=
