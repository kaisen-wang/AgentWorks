# AgentWorks 环境变量配置
# 复制此文件为 .env.local 并填入实际值

# LLM API 配置
NEXT_PUBLIC_LLM_ENDPOINT=https://api.openai.com/v1
# LLM API Key（不要提交到版本控制）
LLM_API_KEY=

# WebSocket 实时通信（可选，不配置则使用本地模式）
NEXT_PUBLIC_WS_URL=

# SQLite 数据库路径（服务端，默认 data/agentworks.db）
DATABASE_PATH=

# 短信网关配置（可选，用于休息模式短信摘要 SOLO-01）
# 支持通用 HTTP 短信网关（Twilio / 阿里云短信 / 自建网关等）
SMS_GATEWAY_URL=
SMS_GATEWAY_SECRET=
SMS_RECIPIENT=
